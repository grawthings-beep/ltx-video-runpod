PORT=8188
LISTEN=0.0.0.0
RUN_DEP_CHECK=0
DOWNLOAD_MODELS=1
HF_TOKEN={{ RUNPOD_SECRET_HF_TOKEN }}
CIVITAI_TOKEN={{ RUNPOD_SECRET_CIVITAI_TOKEN }}
MODEL_MANIFEST_URL=https://raw.githubusercontent.com/YOUR_GITHUB_USER/YOUR_REPO/main/config/ltx-video-models.json
ARIA2_CONNECTIONS=16
ARIA2_SPLITS=16
# Number of model files to download in parallel at startup. Each file still uses
# ARIA2_CONNECTIONS connections, so total streams = DOWNLOAD_JOBS * ARIA2_CONNECTIONS.
# Raise to speed up the first-boot download; lower to 1 if HuggingFace returns 429.
DOWNLOAD_JOBS=4
COMFYUI_ARGS=--reserve-vram 5
