PORT=8188
LISTEN=0.0.0.0
RUN_DEP_CHECK=0
DOWNLOAD_MODELS=1
MODEL_DOWNLOAD_MODE=background
HF_TOKEN={{ RUNPOD_SECRET_HF_TOKEN }}
CIVITAI_TOKEN={{ RUNPOD_SECRET_CIVITAI_TOKEN }}
MODEL_MANIFEST_URL=https://raw.githubusercontent.com/YOUR_GITHUB_USER/YOUR_REPO/main/config/ltx-video-models.json
# Hugging Face downloads use hf_xet. This mode tries to saturate network and CPU.
HF_XET_HIGH_PERFORMANCE=1
HF_HUB_DOWNLOAD_TIMEOUT=120
ARIA2_CONNECTIONS=8
ARIA2_SPLITS=8
# hf_xet parallelizes chunks within each Hugging Face file. Keep this low to avoid
# competing high-performance downloads; non-HF downloads use the same job pool.
DOWNLOAD_JOBS=1
# once: verify a SHA once and cache the result; always: re-read on every boot; never: skip.
VERIFY_MODEL_HASHES=once
COMFYUI_ARGS=--reserve-vram 5
